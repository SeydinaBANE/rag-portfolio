# OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Cohere (https://dashboard.cohere.com/api-keys)
COHERE_API_KEY=your-cohere-key-here

# Modèles
CHAT_MODEL=nvidia/nemotron-3-super-120b-a12b:free
EMBEDDING_MODEL=embed-multilingual-v3.0

# PostgreSQL
POSTGRES_USER=kg_user
POSTGRES_PASSWORD=changeme
POSTGRES_DB=knowledgeforge
DATABASE_URL=postgresql+asyncpg://kg_user:changeme@localhost:5432/knowledgeforge

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=knowledgeforge-rag

# Pipeline
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K_RETRIEVAL=5

# App
LOG_LEVEL=INFO
ENV=development
